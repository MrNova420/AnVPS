# ──────────────────────────────────────────────
cmd_tier() {
    local action="${1:-detect}"; shift 1 2>/dev/null || true
    [ -f "${ANVPS_SRC}/core/lightweight.sh" ] && bash "${ANVPS_SRC}/core/lightweight.sh" "$action" "$@" || err "Lightweight module not installed"
}

cmd_fail2ban() {
    local action="${1:-status}"; shift 1 2>/dev/null || true
    [ -f "${ANVPS_SRC}/core/fail2ban.sh" ] && bash "${ANVPS_SRC}/core/fail2ban.sh" "$action" "$@" || err "fail2ban module not installed"
}

cmd_config_tier() {
    local tier="${1:-}"
    if [ -z "$tier" ]; then cmd_tier info; return; fi
    local cfg="${ANVPS_DIR}/etc/anvps.conf"
    if grep -q "^ANVPS_TIER=" "$cfg" 2>/dev/null; then sed -i "s/^ANVPS_TIER=.*/ANVPS_TIER=\"$tier\"/" "$cfg"
    else echo "ANVPS_TIER=\"$tier\"" >> "$cfg"; fi
    log "Tier set to $tier — restart services to apply"
}

# ──────────────────────────────────────────────
# CONFIG
# ──────────────────────────────────────────────
cmd_config() {
    local cfg="${ANVPS_DIR}/etc/anvps.conf"
    case "${1:-show}" in
        show) [ -f "$cfg" ] && cat "$cfg" || echo "No config found" ;;
        get) local key="${2:-}"; [ -n "$key" ] && grep "^${key}=" "$cfg" 2>/dev/null | cut -d= -f2- || err "Specify key" ;;
        set) local key="${2:-}"; local val="${3:-}"; [ -n "$key" ] && [ -n "$val" ] || { err "Usage: config set KEY VALUE"; return 1; }
            local valid_keys="ANVPS_TIER ANVPS_SSH_TYPE ANVPS_SSH_PORT ANVPS_HTTPD_TYPE ANVPS_BOT_TYPE ANVPS_MONITORING ANVPS_WEB_PORT ANVPS_HTTPS_PORT ANVPS_AUTO_UPDATE ANVPS_UPDATE_INTERVAL ANVPS_AUTO_BACKUP ANVPS_BACKUP_INTERVAL ANVPS_BACKUP_RETENTION ANVPS_LOG_LEVEL ANVPS_LOG_RETENTION_DAYS ANVPS_WATCHDOG ANVPS_WATCHDOG_INTERVAL ANVPS_MONITOR_INTERVAL ANVPS_TUNNEL_TYPE ANVPS_STEALTH ANVPS_STEALTH_START_HOUR ANVPS_STEALTH_END_HOUR ANVPS_OBFUSCATE ANVPS_OBFUSCATE_INTERVAL ANVPS_ENCRYPT_STORAGE ANVPS_TAMPER_DETECTION ANVPS_TAMPER_MAX_FAILED ANVPS_DEAD_MAN_DAYS ANVPS_VPN_KILLSWITCH ANVPS_TOR_ENABLED ANVPS_TIMEZONE ANVPS_PORT_BASE ANVPS_VPN_IFACE ANVPS_VPN_PORT ANVPS_MLOCK_MEMORY"
            if ! echo "$valid_keys" | grep -qw "$key"; then local suggestion=$(echo "$valid_keys" | tr ' ' '\n' | grep -i "${key:0:4}" | head -1); [ -n "$suggestion" ] && err "Unknown key '$key' — did you mean '$suggestion'?" || err "Unknown key '$key'. Valid keys: ANVPS_TIER, ANVPS_SSH_PORT, ..."; return 1; fi
            if grep -q "^${key}=" "$cfg" 2>/dev/null; then sed -i "s/^${key}=.*/${key}=\"${val}\"/" "$cfg"
            else echo "${key}=\"${val}\"" >> "$cfg"; fi; log "${key}=${val}" ;;
        load) local profile="${2:-full}"; local pf="${ANVPS_DIR}/etc/profiles/${profile}.conf"
            [ -f "$pf" ] && cp "$pf" "$cfg" && log "Loaded profile: $profile" || { pf="${ANVPS_SRC}/../config/profiles/${profile}.conf"; [ -f "$pf" ] && cp "$pf" "$cfg" && log "Loaded profile: $profile" || err "Profile not found: $profile"; } ;;
        *) echo "Usage: anvps config {show|get|set|load} [key] [value]" ;;
    esac
}

# ──────────────────────────────────────────────
# LOGS
# ──────────────────────────────────────────────
cmd_logs() {
    local service="${1:-}"; local lines="${2:-50}"
    if [ -n "$service" ]; then
        local logf="${ANVPS_DIR}/logs/${service}.log"
        [ -f "$logf" ] && tail -n "$lines" "$logf" || err "No logs for '$service'"
    else echo "Available logs:"; ls -lh "${ANVPS_DIR}/logs/"*.log 2>/dev/null | awk '{print "  " $9 " (" $5 ")"}' || echo "  (none)"; fi
}

# ──────────────────────────────────────────────
# DOCTOR
# ──────────────────────────────────────────────
cmd_doctor() {
    echo "  AnVPS Diagnostic"; echo "  $(printf '%0.s-' {1..40})"; echo ""
    local checks=0 passed=0
    check() { checks=$((checks+1)); if "$@" &>/dev/null; then echo "  [PASS] $*"; passed=$((passed+1)); else echo "  [FAIL] $*"; fi; }
    check test -d "$ANVPS_DIR"; check test -f "${ANVPS_DIR}/etc/anvps.conf"; check command -v bash; check command -v curl
    for pidf in "${ANVPS_DIR}/services"/*.pid; do [ -f "$pidf" ] || continue; local pid=$(cat "$pidf"); check kill -0 "$pid" 2>/dev/null; done
    echo ""; echo "  Results: $passed/$checks"
}

# ──────────────────────────────────────────────
# HELP
# ──────────────────────────────────────────────
cmd_help() {
    echo "  AnVPS v${ANVPS_VERSION} — Android VPS Management"; echo ""
    echo "  Usage: anvps <command> [options]"; echo ""
    echo "  Core:"; echo "    status              Show system status"
    echo "    service             Manage services (list|install|start|stop|restart|setup)"
    echo "    monitor [interval]  Live resource monitor"
    echo "    update              Run auto-updates"
    echo "    backup              Backup management (create|list|restore)"
    echo "    logs [service] [n]  View logs"
    echo "    doctor              Run diagnostics"
    echo ""
    echo "  Networking:"; echo "    tunnel              Tunnel management (start|stop|status)"
    echo "    tor                 Tor gateway (start|stop|status)"
    echo "    killswitch          VPN kill switch (enable|disable|status|test)"
    echo ""
    echo "  Security:"; echo "    security            Security tools (status|scan|harden|wipe)"
    echo "    stealth             Stealth mode (enable|disable|status)"
    echo "    obfuscate           Device obfuscation (all|hostname|ssh|mac|http|status)"
    echo "    encrypt             Encrypted storage (init|unmount|status)"
    echo "    tamper              Tamper detection (init|verify|check|status)"
    echo "    fail2ban            Fail2ban (start|stop|restart|status)"
    echo ""
    echo "  Config:"; echo "    config              Configuration (show|get|set|load)"
    echo "    tier                RAM tier detection (detect|info|select-ssh|select-httpd)"
    echo "    uninstall           Fully remove AnVPS"
    echo "    help                This help"
    echo "    version             Show version"
}

# ──────────────────────────────────────────────
# MAIN
# ──────────────────────────────────────────────
cmd_uninstall() {
    if [ -f "${ANVPS_DIR}/../setup/uninstall.sh" ]; then
        bash "${ANVPS_DIR}/../setup/uninstall.sh"
    elif [ -f "$(dirname "$0")/../../setup/uninstall.sh" ]; then
        bash "$(dirname "$0")/../../setup/uninstall.sh"
    else
        warn "Uninstaller not found — remove ${ANVPS_DIR} manually"
    fi
}

main() {
    ensure_dir; load_config
    [ $# -eq 0 ] && { cmd_status; return; }
    local cmd="${1:-}"; shift 1 2>/dev/null || true
    case "$cmd" in
        status|service|monitor|update|backup|tunnel|logs|doctor|version|help|fail2ban)
            "cmd_$cmd" "$@" ;;
        security|stealth|obfuscate|encrypt|tor|tamper|killswitch|tier)
            "cmd_$cmd" "$@" ;;
        config) cmd_config "$@" ;;
        uninstall) cmd_uninstall ;;
        --help|-h) cmd_help ;;
        *) err "Unknown: $cmd"; echo ""; cmd_help ;;
    esac
}

main "$@"
